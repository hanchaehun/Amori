{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amori.app/schemas/persona.json",
  "title": "Persona",
  "description": "사용자의 초기/누적 시나리오 답변을 LLM이 분석해 만든 페르소나 카드. pgvector에 임베딩과 함께 저장된다.",
  "type": "object",
  "required": ["user_id", "traits", "communication_style", "humor_style", "value_keywords", "speech_style", "sample_messages", "ai_generated"],
  "properties": {
    "user_id": { "type": "string" },
    "traits": {
      "type": "array",
      "description": "근거 있는 카테고리만 (연락 템포 / 유머 / 갈등 / 데이트 / 돈·시간 / 관계 속도 / 경계선 / 위로 중 1~8개). 빈 카테고리는 앱이 '아직 몰라요'로 렌더 — 근거: docs/persona_science_rationale.md",
      "items": {
        "type": "object",
        "required": ["category", "summary", "keywords"],
        "properties": {
          "category": { "type": "string" },
          "summary": { "type": "string", "description": "한 문장 요약" },
          "keywords": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" }, "description": "근거 답변 코드 (예 'R-2:A')" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "코드가 evidence 수로 계산 — LLM 자기보고 아님" },
          "user_edited": { "type": "boolean", "description": "사용자 직접 수정 — LLM 업데이트가 덮지 못함" }
        }
      },
      "minItems": 1,
      "maxItems": 8
    },
    "communication_style": { "type": "string", "description": "예: '느린 일상·진심형'" },
    "humor_style": { "type": "string", "description": "예: '잔잔한 유머·드라이톤'" },
    "value_keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "가치관 핵심 키워드 3~7개"
    },
    "speech_style": {
      "type": "object",
      "description": "에이전트 발화 충실도의 핵심. 주관식 [말투 샘플](9-x 문항)이 있으면 샘플에서 추출, 없으면 객관식 성향에서 추론. 샘플에서 못 뽑는 항목은 기본값(중간/빈 문자열).",
      "required": ["formality", "emoji_usage", "laugh_style", "sentence_length", "tone_keywords"],
      "properties": {
        "formality": { "type": "string", "enum": ["반말", "존댓말", "혼용"] },
        "emoji_usage": { "type": "string", "enum": ["거의 안 씀", "가끔", "자주"] },
        "laugh_style": { "type": "string", "description": "웃음 표현 습관. 예: 'ㅋㅋ', 'ㅎㅎ', '안 씀'" },
        "sentence_length": { "type": "string", "enum": ["짧고 간결", "보통", "길게 풀어 씀"] },
        "tone_keywords": { "type": "array", "items": { "type": "string" }, "description": "말투 톤 키워드 2~4개. 예: 담백, 장난스러움, 차분" },
        "verbal_habits": { "type": "string", "description": "감탄사·말버릇 (헉/헐/아 맞다 등, 없으면 빈 문자열)" },
        "punctuation_habits": { "type": "string", "description": "부호·감정 표지 습관 (ㅠㅠ/!!/…/~ 등, 없으면 빈 문자열)" },
        "reaction_style": { "type": "string", "enum": ["공감형", "논리형", "중간"], "description": "반응 성향. 못 뽑으면 '중간'" }
      }
    },
    "sample_messages": {
      "type": "array",
      "description": "few-shot 발화 앵커 1~3개. [말투 샘플]이 있으면 사용자가 직접 쓴 문장을 거의 그대로 사용.",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 3
    },
    "voice_stats": {
      "type": ["object", "null"],
      "description": "코드가 계산한 말투 측정값 (backend voice_features — LLM 추측 금지). 실측 발화가 없으면 null. speech_style(LLM 추론 요약)과 달리 시뮬 프롬프트의 수치 지시 원천.",
      "properties": {
        "sample_count": { "type": "integer", "description": "실측 발화 수 = 신뢰도의 근거" },
        "formality_ratio": { "type": "object", "description": "{\"존댓말\": 0.9, \"반말\": 0.1} — 어미 표지가 있는 메시지만 분모. 합이 0이면 근거 없음." },
        "len_chars": { "type": "object", "description": "{\"p25\", \"p50\", \"p75\"} 글자 수 백분위" },
        "laugh": { "type": "object", "description": "{\"token\": \"ㅋ\", \"avg_run\": 3.2, \"per_msg\": 0.6}" },
        "emoji": { "type": "object", "description": "{\"per_msg\": 0.0, \"inventory\": []} — 실제 쓰는 이모지만" },
        "punct_per_msg": { "type": "object", "description": "부호 습관 메시지당 빈도 (~/!!/…/ㅠㅠ/^^/;;). 0인 키는 없음 = 안 쓰는 습관." },
        "question_ratio": { "type": "number" },
        "interjections": { "type": "array", "items": { "type": "string" }, "description": "감탄사 빈도순 (헉/헐 등)" }
      }
    },
    "sample_bank": {
      "type": "array",
      "description": "실측 발화 뱅크 — sample_messages(1~3)의 원천이자 확장. 출처 등급: user_written > kakao > llm_seed(실측이 들어오면 교체).",
      "items": {
        "type": "object",
        "required": ["text", "source"],
        "properties": {
          "text": { "type": "string" },
          "register": { "type": "string", "description": "말투 단면 태그. v1은 문항 코드(9-1 등), 레지스터 라벨은 P1." },
          "source": { "type": "string", "enum": ["user_written", "kakao", "llm_seed"] },
          "collected_at": { "type": "string", "description": "ISO 날짜" }
        }
      }
    },
    "voice_confidence": {
      "type": ["number", "null"],
      "description": "말투 신뢰도 0~0.9 — sample_count 기반(1-exp(-n/7)). 상한 0.9는 카톡 import·레지스터 커버리지 몫."
    },
    "response_preferences": {
      "type": "array",
      "description": "정답지 — '이 상황에서 어떤 답장을 받고 싶은가'. 평가 전용: 리포트 채점(반응성 매칭)에만 사용. 시뮬 프롬프트 주입 금지(정직한 시뮬 훼손), 매칭 하드필터 금지(명시적 선호는 실제 끌림을 예측하지 못함 — Eastwick&Finkel 2008, Joel 2017).",
      "items": {
        "type": "object",
        "required": ["desired_reply"],
        "properties": {
          "code": { "type": "string", "description": "유발 문항 코드" },
          "situation": { "type": "string" },
          "desired_reply": { "type": "string", "description": "사용자가 직접 쓴 '받고 싶은 답장'" },
          "collected_at": { "type": "string" }
        }
      }
    },
    "embedding": {
      "type": ["array", "null"],
      "items": { "type": "number" },
      "description": "Gemini 임베딩으로 생성한 1024차원 정규화 벡터 (pgvector 인덱스 차원 고정)."
    },
    "ai_generated": {
      "type": "boolean",
      "const": true,
      "description": "AI 기본법 준수: AI 생성물 라벨"
    }
  }
}
