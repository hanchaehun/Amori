# LLM Provider: mock | hf | midm_local
LLM_PROVIDER=mock

# LLM endpoints (only needed for hf/midm_local)
LLM_BASE_URL=http://localhost:8001

# HuggingFace (only for hf provider)
HF_API_TOKEN=

# Database
DATABASE_URL=postgresql+asyncpg://amori:amori_dev@localhost:5432/amori

# Firebase
FIREBASE_PROJECT_ID=amori-260523
# Firebase 서비스 계정 키 (Firebase Console → 프로젝트 설정 → 서비스 계정 → 비공개 키 생성)
# 이 환경변수는 Settings가 아닌 Firebase Admin SDK가 직접 읽습니다.
GOOGLE_APPLICATION_CREDENTIALS=app/your-firebase-adminsdk.json

# Rate Limiting
DAILY_SIMULATION_LIMIT=5
DAILY_MEET_REQUEST_LIMIT=1

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
