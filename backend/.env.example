# LLM Provider: mock (오프라인 데모/테스트) | gemini (실 LLM) | modoo (DevDive 채팅 + Gemini 임베딩)
LLM_PROVIDER=mock

# Gemini — gemini 모드에선 채팅+임베딩, modoo 모드에선 임베딩 전용으로 사용.
# (LLM_PROVIDER=gemini 또는 modoo 일 때 필수)
GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# DevDive(모두의창업) (LLM_PROVIDER=modoo 일 때 필수) — 채팅 담당. 임베딩은 위 Gemini 키 사용.
MODOO_API_KEY=
# MODOO_BASE_URL=https://modoo.devdive.me
# MODOO_CHAT_MODEL=modoo-text-pro

# Database — 팀 공용 관리형 Postgres (Neon 등, pgvector 내장). Docker는 더 이상 쓰지 않는다.
# URL은 팀 시크릿 채널에서 받아 채운다 (README '데이터베이스' 절 참고).
# 형식: postgresql+asyncpg://<user>:<password>@<host>/<db>?ssl=require
#  - 드라이버 접두사는 postgresql+asyncpg:// (Neon 콘솔의 postgresql:// 를 바꿔 쓸 것)
#  - Supabase면 pooler(6543)가 아니라 직접 연결(5432) 포트 — asyncpg가 pooler와 충돌
DATABASE_URL=

# Firebase — 백엔드는 projectId만으로 ID 토큰을 검증한다 (서비스 계정 키 불필요)
FIREBASE_PROJECT_ID=amori-260523

# Rate Limiting
DAILY_SIMULATION_LIMIT=3
DAILY_MEET_REQUEST_LIMIT=1

# DEBUG=true — 'Bearer dev:<uid>' 인증 우회 허용 (로컬 전용, 운영 배포 시 false)
DEBUG=true
