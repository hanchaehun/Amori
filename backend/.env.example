# LLM Provider: mock (오프라인 데모/테스트) | gemini (실 LLM) | modoo (DevDive 채팅 + Gemini 임베딩)
LLM_PROVIDER=mock

# Gemini — gemini 모드에선 채팅+임베딩, modoo 모드에선 임베딩 전용으로 사용.
# (LLM_PROVIDER=gemini 또는 modoo 일 때 필수)
GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# DevDive(모두의창업) (LLM_PROVIDER=modoo 일 때 필수) — 채팅 담당. 임베딩은 위 Gemini 키 사용.
MODOO_API_KEY=
# MODOO_BASE_URL=https://modoo.devdive.me
# MODOO_CHAT_MODEL=modoo-text-pro

# Database
DATABASE_URL=postgresql+asyncpg://amori:amori_dev@localhost:5432/amori

# Firebase
FIREBASE_PROJECT_ID=amori-260523
# Firebase 서비스 계정 키 (Firebase Console → 프로젝트 설정 → 서비스 계정 → 비공개 키 생성)
# 이 환경변수는 Settings가 아닌 Firebase Admin SDK가 직접 읽습니다.
GOOGLE_APPLICATION_CREDENTIALS=app/your-firebase-adminsdk.json

# Rate Limiting
DAILY_SIMULATION_LIMIT=3
DAILY_MEET_REQUEST_LIMIT=1

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
